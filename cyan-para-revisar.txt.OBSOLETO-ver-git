# Prompt usado especificamente na análise técnica de arquivo individual
ANALYSIS_PROMPT_TEMPLATE = """Analise tecnicamente o arquivo "{filename}" enviado abaixo.

Verifique:
1. Formato e adequação para produção gráfica offset (CMYK)
2. Resolução e qualidade visual (pixelado, serrilhado, nitidez)
3. Se for logo: é vetor real (AI/EPS/PDF vetorial/SVG)? PNG transparente? PNG com fundo? Baixa res?
4. Se for arte: está no formato leque/mockup? Plano? Resolução adequada?
5. Se for QR Code ou código de barras: é vetor ou bitmap?
6. Qualquer problema técnico que impeça ou dificulte a produção

Responda SEMPRE neste formato exato:

**{filename}**
Status: [✅ Aprovado para produção / ⚠️ Requer intervenção / 🔴 Recusar — inadequado para produção]

Análise técnica:
[descrição objetiva do que você observou]

Recomendação:
[o que o atendimento deve pedir ao cliente, ou "Nenhuma — arquivo OK"]"""


class OpenAIClient:
    def __init__(self, api_key: str, model: str = "gpt-4o", max_tokens: int = 4096):
        self.client = AsyncOpenAI(api_key=api_key)
        self.model = model
        self.max_tokens = max_tokens

    async def generate_briefing(self, content: list) -> str:
        """Gera briefing estruturado a partir de um payload multimodal."""
        response = await self.client.chat.completions.create(
            model=self.model,
            messages=[
                {"role": "system", "content": SYSTEM_PROMPT},
                {"role": "user", "content": content},
            ],
            max_tokens=self.max_tokens,
        )
        return response.choices[0].message.content or ""

    async def analyze_file(self, file_content: list, filename: str) -> str:
        """Analisa tecnicamente um arquivo individual."""
        prompt = ANALYSIS_PROMPT_TEMPLATE.format(filename=filename)
        response = await self.client.chat.completions.create(
            model=self.model,
            messages=[
                {"role": "system", "content": SYSTEM_PROMPT},
                {
                    "role": "user",
                    "content": [{"type": "text", "text": prompt}, *file_content],
                },
            ],
            max_tokens=1024,
        )
        return response.choices[0].message.content or ""
